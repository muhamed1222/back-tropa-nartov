{
  "kind": "collectionType",
  "collectionName": "routes",
  "info": {
    "singularName": "route",
    "pluralName": "routes",
    "displayName": "Маршрут",
    "description": "Туристические маршруты"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "maxLength": 200
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "text",
      "required": false,
      "maxLength": 500
    },
    "route_type": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::route-type.route-type",
      "inversedBy": "routes"
    },
    "places": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::place.place",
      "inversedBy": "routes"
    },
    "reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::review.review",
      "mappedBy": "route"
    },
    "favorites": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::favorite.favorite",
      "mappedBy": "route"
    },
    "visited_places": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::visited-place.visited-place",
      "mappedBy": "route"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "rating": {
      "type": "decimal",
      "required": false,
      "default": 3.5,
      "min": 0.0,
      "max": 5.0
    }
  }
}

