{
  "kind": "collectionType",
  "collectionName": "routes",
  "info": {
    "singularName": "route",
    "pluralName": "routes",
    "displayName": "Маршрут",
    "description": "Туристические маршруты"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "maxLength": 200
    },
    "description": {
      "type": "richtext",
      "required": true
    },
    "overview": {
      "type": "richtext"
    },
    "history": {
      "type": "richtext"
    },
    "type": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::type.type",
      "inversedBy": "routes",
      "required": true
    },
    "area": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::area.area",
      "inversedBy": "routes",
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "stops": {
      "type": "component",
      "repeatable": true,
      "component": "route.route-stop",
      "required": false
    },
    "distance_km": {
      "type": "decimal",
      "required": false,
      "min": 0
    },
    "duration_hours": {
      "type": "decimal",
      "required": false,
      "min": 0
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "places_count": {
      "type": "integer",
      "required": false
    },
    "reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::review.review",
      "mappedBy": "route"
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category",
      "inversedBy": "routes"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag",
      "inversedBy": "routes"
    }
  }
}

