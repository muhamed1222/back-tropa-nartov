{
  "kind": "collectionType",
  "collectionName": "routes",
  "info": {
    "singularName": "route",
    "pluralName": "routes",
    "displayName": "Route",
    "description": "Туристические маршруты"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "maxLength": 200
    },
    "description": {
      "type": "richtext",
      "required": true
    },
    "overview": {
      "type": "richtext"
    },
    "history": {
      "type": "richtext"
    },
    "distance": {
      "type": "decimal",
      "required": true
    },
    "duration": {
      "type": "decimal"
    },
    "rating": {
      "type": "decimal",
      "default": 0
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "type_id": {
      "type": "integer",
      "required": true
    },
    "area_id": {
      "type": "integer",
      "required": true
    },
    "type": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::type.type",
      "inversedBy": "routes"
    },
    "area": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::area.area",
      "inversedBy": "routes"
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category"
    },
    "reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::review.review",
      "mappedBy": "route"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag"
    }
  }
}

