{
  "kind": "collectionType",
  "collectionName": "types",
  "info": {
    "singularName": "type",
    "pluralName": "types",
    "displayName": "Type",
    "description": "Типы маршрутов и мест"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true,
      "maxLength": 100
    },
    "entity_type": {
      "type": "enumeration",
      "enum": ["place", "route"],
      "required": true
    },
    "description": {
      "type": "richtext"
    },
    "routes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::route.route",
      "mappedBy": "type"
    },
    "places": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::place.place",
      "mappedBy": "type"
    }
  }
}

