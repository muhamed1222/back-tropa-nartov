{
  "kind": "collectionType",
  "collectionName": "reviews",
  "info": {
    "singularName": "review",
    "pluralName": "reviews",
    "displayName": "Отзыв",
    "description": "Отзывы о местах и маршрутах"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "text": {
      "type": "text",
      "required": false,
      "maxLength": 2000
    },
    "rating": {
      "type": "integer",
      "required": true,
      "min": 1,
      "max": 5
    },
    "user_name": {
      "type": "string",
      "required": false,
      "maxLength": 100
    },
    "date": {
      "type": "datetime",
      "required": false
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "user_id": {
      "type": "integer",
      "required": false
    },
    "likes": {
      "type": "integer",
      "default": 0
    },
    "place": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::place.place",
      "inversedBy": "reviews"
    },
    "route": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::route.route",
      "inversedBy": "reviews"
    }
  }
}

