{
  "kind": "collectionType",
  "collectionName": "places",
  "info": {
    "singularName": "place",
    "pluralName": "places",
    "displayName": "Место",
    "description": "Места и достопримечательности"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "maxLength": 200
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "images": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": ["images"]
    },
    "history": {
      "type": "richtext",
      "required": false
    },
    "address": {
      "type": "string",
      "required": false,
      "maxLength": 500
    },
    "latitude": {
      "type": "decimal",
      "required": false
    },
    "longitude": {
      "type": "decimal",
      "required": false
    },
    "working_hours": {
      "type": "text",
      "required": false,
      "maxLength": 500
    },
    "phone": {
      "type": "string",
      "required": false,
      "maxLength": 50
    },
    "website": {
      "type": "string",
      "required": false,
      "maxLength": 500
    },
    "area": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::area.area",
      "inversedBy": "places"
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category",
      "inversedBy": "places"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag",
      "inversedBy": "places"
    },
    "routes": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::route.route",
      "mappedBy": "places"
    },
    "reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::review.review",
      "mappedBy": "place"
    },
    "favorites": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::favorite.favorite",
      "mappedBy": "place"
    },
    "visited_places": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::visited-place.visited-place",
      "mappedBy": "place"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    }
  }
}

