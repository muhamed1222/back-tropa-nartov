{
  "kind": "collectionType",
  "collectionName": "places",
  "info": {
    "singularName": "place",
    "pluralName": "places",
    "displayName": "Place",
    "description": "Места и достопримечательности"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "maxLength": 200
    },
    "type_name": {
      "type": "string",
      "maxLength": 100
    },
    "description": {
      "type": "richtext",
      "required": true
    },
    "overview": {
      "type": "richtext"
    },
    "history": {
      "type": "richtext"
    },
    "address": {
      "type": "string",
      "required": true,
      "maxLength": 500
    },
    "hours": {
      "type": "string",
      "maxLength": 200
    },
    "weekend": {
      "type": "string",
      "maxLength": 100
    },
    "entry": {
      "type": "string",
      "maxLength": 100
    },
    "contacts": {
      "type": "string",
      "maxLength": 200
    },
    "contacts_email": {
      "type": "email",
      "maxLength": 200
    },
    "latitude": {
      "type": "decimal",
      "required": true
    },
    "longitude": {
      "type": "decimal",
      "required": true
    },
    "rating": {
      "type": "decimal",
      "default": 0
    },
    "opening_hours": {
      "type": "string",
      "maxLength": 100
    },
    "type_id": {
      "type": "integer"
    },
    "area_id": {
      "type": "integer",
      "required": true
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "images": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::image.image",
      "mappedBy": "place"
    },
    "reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::review.review",
      "mappedBy": "place"
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag"
    },
    "area": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::area.area",
      "inversedBy": "places"
    },
    "type": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::type.type",
      "inversedBy": "places"
    }
  }
}

